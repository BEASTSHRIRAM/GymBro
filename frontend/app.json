{
  "expo": {
    "name": "GymBro",
    "slug": "gymbro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymbro.app",
      "infoPlist": {
        "NSCameraUsageDescription": "GymBro needs camera access for AI form checking and body scan.",
        "NSMicrophoneUsageDescription": "GymBro needs microphone access for voice coaching.",
        "NSPhotoLibraryUsageDescription": "GymBro needs photo library access to save workout videos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/AdaptiveIcon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.gymbro.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/Favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-av",
      [
        "expo-secure-store",
        {}
      ]
    ]
  }
}